APP_ENV=dev

# Supabase Postgres connection string (SQLAlchemy + psycopg2 형식)
DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT_REF]:[DBPASSWORD]@a[POOLER_HOST]:5432/postgres
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare R2 (S3 호환 오브젝트 스토리지)
R2_ENDPOINT_URL=https://[ACCOUNT_ID].r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=[ACCESS_KEY_ID]
R2_SECRET_ACCESS_KEY=[SECRET_ACCESS_KEY]
R2_BUCKET_NAME=kx-b2
R2_PUBLIC_URL=https://pub-[HASH].r2.dev

# Claude API (통합 프롬프트 생성)
ANTHROPIC_API_KEY=[ANTHROPIC_API_KEY]
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI API (GPT image 생성)
OPENAI_API_KEY=[OPENAI_API_KEY]
OPENAI_IMAGE_MODEL=gpt-image-1

# Gemini API (Gemini image 생성)
GEMINI_API_KEY=[GEMINI_API_KEY]
GEMINI_IMAGE_MODEL=gemini-3.5-flash-image
